{
  "name": "poc-island",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate-routes": "tsr generate",
    "dev": "vite dev",
    "build": "vite build",
    "lint": "oxlint --type-aware src",
    "lint:fix": "oxlint --type-aware --fix src",
    "format": "oxfmt --check src",
    "format:fix": "oxfmt --write src",
    "check": "oxlint --type-aware src && oxfmt --check src",
    "check:fix": "oxlint --type-aware --fix src && oxfmt --write src",
    "typecheck": "tsgo --noEmit",
    "test": "vitest --run",
    "knip": "knip",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv",
    "db:generate": "drizzle-kit generate",
    "db:push:local": "bash scripts/setup-local-db.sh",
    "db:seed:local": "bun run scripts/seed-local.ts",
    "tunnel": "bash scripts/tunnel.sh"
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.2.3",
    "@tanstack/react-router": "1.170.15",
    "@tanstack/react-start": "1.168.25",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "0.525.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "3.3.1",
    "zod": "4.0.10"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.35.0",
    "@cloudflare/workers-types": "4.20260501.1",
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/router-cli": "1.167.17",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@typescript/native-preview": "7.0.0-dev.20260501.1",
    "@vitejs/plugin-react": "6.0.1",
    "dotenv": "17.2.1",
    "drizzle-kit": "0.31.4",
    "jsdom": "^29.1.1",
    "knip": "^6.20.0",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "tailwindcss": "4.2.4",
    "tw-animate-css": "1.3.6",
    "typescript": "5.8.3",
    "vite": "8.0.16",
    "vitest": "^4.1.9",
    "wrangler": "4.87.0"
  }
